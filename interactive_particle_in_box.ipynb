import numpy as np
import matplotlib.pyplot as plt
import ipywidgets as widgets
from ipywidgets import interact

# Wavefunction defined here
def psi(n, x, L):
    return np.sqrt(2 / L) * np.sin(n * np.pi * x / L)

# Probability density function defined here whose values will come from sliders
def probability_density(n, x, L):
    return psi(n, x, L)**2

# Interactive plotting function
def plot_probability_density(n=1, L=1.0):

    x = np.linspace(0, L, 1000)

    plt.figure(figsize=(10,6))

    plt.plot(x, probability_density(n, x, L), linewidth=2)

    plt.title("Interactive Probability Density in a Particle in a Box")

    plt.xlabel("Position x")
    plt.ylabel(r"$|\psi(x)|^2$")

    plt.xlim(0, L)
    plt.ylim(0, 3)

    plt.grid()
